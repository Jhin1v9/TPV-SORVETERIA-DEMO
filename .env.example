# ─── Supabase ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ─── Stripe (Pagamentos Online: PWA) ───
# Chave pública para o frontend (PWA Cliente)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Chave secreta para Edge Functions (NÃO expor no frontend)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Comprovantes) ───
# RESEND_API_KEY=re_...

# ─── Kiosk Físico ───
# VITE_KIOSK_MODE=web          # 'web' para kiosk web, 'physical' para kiosk com TPV
# VITE_PRINTER_ENABLED=false   # 'true' se impressora térmica conectada
# VITE_TPV_PROVIDER=elo        # 'elo', 'ingenico', 'pax', 'verifone'

# ─── Modo de Pagamento ───
# VITE_PAYMENT_MODE=mock       # 'mock' para demo, 'real' para produção
